{
  "name": "@eth-optimism/actions-service",
  "private": true,
  "description": "Node service running Actions SDK.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum-optimism/actions.git",
    "directory": "packages/demo/backend"
  },
  "homepage": "https://github.com/ethereum-optimism/actions/tree/main/packages/demo/backend#readme",
  "bugs": {
    "url": "https://github.com/ethereum-optimism/actions/issues"
  },
  "version": "0.2.3",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc && resolve-tspaths",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint \"**/*.{ts,tsx}\" && prettier --check \"**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{ts,tsx}\" --fix && prettier \"**/*.{ts,tsx}\" --write --log-level=warn",
    "dev": "tsx src/index.ts",
    "dev:local": "LOCAL_DEV=true pnpm dev",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "attribution": "tsx scripts/attribution.ts",
    "deploy:uniswap": "tsx scripts/deployUniswapMarket.ts",
    "deploy:velodrome": "tsx scripts/deployVelodromeMarket.ts"
  },
  "dependencies": {
    "@eth-optimism/actions-sdk": "workspace:*",
    "@eth-optimism/utils-app": "^0.0.6",
    "@eth-optimism/viem": "^0.4.13",
    "@hono/node-server": "^1.19.13",
    "@privy-io/node": "^0.3.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.5",
    "envalid": "^8.1.0",
    "hono": "^4.12.14",
    "viem": "^2.24.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "typescript": "^5.2.2",
    "undici": "^6.23.0",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  }
}
